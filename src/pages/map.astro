---
import Base from '../layouts/Base.astro';
import SectionHead from '../components/SectionHead.astro';
import { getGeoPhotos, accession } from '../lib/photos';

const geo = await getGeoPhotos();
const features = geo.map((p, i) => ({
  id: p.id,
  src: p.data.src,
  title: p.data.title ?? p.data.location?.place ?? 'Untitled',
  place: p.data.location?.place ?? '',
  accession: accession(i),
  lat: p.data.location!.lat,
  lng: p.data.location!.lng,
}));
---

<Base title="The Archive — Map">
  <SectionHead
    eyebrow="Geolocated frames"
    title="Map"
    count={features.length}
  />

  {
    features.length === 0 ? (
      <p class="empty">No geotagged photographs yet.</p>
    ) : (
      <div id="map" role="application" aria-label="Map of photograph locations" />
    )
  }

  <!-- MapLibre GL: open-source, no API token required. -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/maplibre-gl@4.7.0/dist/maplibre-gl.css"
  />

  <script
    is:inline
    define:vars={{ features }}
    type="module"
  >
    if (features.length) {
      // MapLibre's dist file is a UMD bundle that attaches to window.
      // Load it as a script tag and read the global it defines.
      if (!window.maplibregl) {
        await new Promise((resolve, reject) => {
          const s = document.createElement('script');
          s.src = 'https://unpkg.com/maplibre-gl@4.7.0/dist/maplibre-gl.js';
          s.onload = resolve;
          s.onerror = reject;
          document.head.appendChild(s);
        });
      }
      const maplibregl = window.maplibregl;

      const map = new maplibregl.Map({
        container: 'map',
        // CARTO dark basemap style — free, no token.
        style: 'https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json',
        center: [features[0].lng, features[0].lat],
        zoom: 2,
      });
      map.addControl(new maplibregl.NavigationControl(), 'top-right');

      const bounds = new maplibregl.LngLatBounds();
      for (const f of features) {
        bounds.extend([f.lng, f.lat]);
        const el = document.createElement('a');
        el.className = 'pin';
        el.href = `/photo/${f.id}`;
        el.setAttribute('aria-label', f.title);

        const popup = new maplibregl.Popup({ offset: 16, closeButton: false })
          .setHTML(
            `<figure class="pop">
               <img src="${f.src}" alt="${f.title}" loading="lazy" />
               <figcaption>
                 <span class="pop-acc">${f.accession}</span>
                 <span class="pop-place">${f.place}</span>
               </figcaption>
             </figure>`
          );

        new maplibregl.Marker({ element: el })
          .setLngLat([f.lng, f.lat])
          .setPopup(popup)
          .addTo(map);
      }
      if (features.length > 1) {
        map.fitBounds(bounds, { padding: 80, maxZoom: 12, duration: 0 });
      } else {
        map.setZoom(9);
      }
    }
  </script>

  <style is:global>
    #map {
      width: 100%;
      height: min(72vh, 720px);
      border: 1px solid var(--ink-faint);
    }
    .pin {
      width: 14px;
      height: 14px;
      background: var(--signal);
      border: 2px solid var(--canvas);
      border-radius: 50%;
      cursor: pointer;
      box-shadow: 0 0 0 1px var(--signal);
    }
    .maplibregl-popup-content {
      background: var(--canvas-raised);
      padding: 0;
      border: 1px solid var(--ink-faint);
      border-radius: 0;
    }
    .pop { margin: 0; width: 200px; }
    .pop img { width: 100%; height: 130px; object-fit: cover; }
    .pop figcaption {
      display: flex;
      justify-content: space-between;
      padding: 0.5rem 0.6rem;
      font-family: var(--font-mono);
      font-size: 0.68rem;
    }
    .pop-acc { color: var(--signal); }
    .pop-place { color: var(--ink-dim); }
    .maplibregl-popup-tip { display: none; }
  </style>

  <style>
    .empty {
      color: var(--ink-dim);
      font-family: var(--font-mono);
      font-size: 0.85rem;
    }
  </style>
</Base>