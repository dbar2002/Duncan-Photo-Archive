---
import Base from '../layouts/Base.astro';
import Gallery from '../components/Gallery.astro';
import SectionHead from '../components/SectionHead.astro';
import { getPhotosByYear, getPhotos } from '../lib/photos';

const byYear = await getPhotosByYear();
const total = (await getPhotos()).length;

// Running offset keeps accession numbers globally stable across year blocks.
let offset = 0;
const blocks = byYear.map(([year, photos]) => {
  const startIndex = offset;
  offset += photos.length;
  return { year, photos, startIndex };
});
---

<Base title="The Archive — Timeline">
  <SectionHead eyebrow="Chronology" title="Timeline" count={total} />

  {
    blocks.map(({ year, photos, startIndex }) => (
      <section class="year">
        <div class="year-rule">
          <span class="year-label">{year}</span>
          <span class="accession">{photos.length}</span>
        </div>
        <Gallery photos={photos} startIndex={startIndex} />
      </section>
    ))
  }

  <style>
    .year { margin-bottom: 4rem; }
    .year-rule {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      border-bottom: 1px solid var(--ink-faint);
      padding-bottom: 0.75rem;
      margin-bottom: 1.75rem;
    }
    .year-label {
      font-family: var(--font-display);
      font-size: 2rem;
      color: var(--signal);
    }
  </style>
</Base>
