---
import Base from '../layouts/Base.astro';
import Gallery from '../components/Gallery.astro';
import SectionHead from '../components/SectionHead.astro';
import { getPhotos } from '../lib/photos';

const photos = await getPhotos();
---

<Base title="The Archive — Index">
  <SectionHead
    eyebrow="Complete index · newest first"
    title="Every frame, catalogued."
    count={photos.length}
  />
  {
    photos.length === 0 ? (
      <p class="empty prose">
        No photographs yet. Drop images into <code>public/images/originals/</code>,
        run <code>npm run metadata</code>, then reload.
      </p>
    ) : (
      <Gallery photos={photos} />
    )
  }

  <style>
    .empty {
      color: var(--ink-dim);
      font-family: var(--font-mono);
      font-size: 0.85rem;
    }
    code {
      color: var(--signal);
      font-family: var(--font-mono);
    }
  </style>
</Base>
